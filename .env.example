# =============================================================================
# Exemplo de variáveis de ambiente
# Copie para .env e ajuste os valores. NUNCA commite o .env real.
# =============================================================================

# ───────────────────────── Aplicação ─────────────────────────
APP_NAME="WebAPI Start"
APP_ENV=development          # development | testing | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0

# ───────────────────────── Banco de Dados (PostgreSQL) ─────────────────────────
# Hostname:
#   - "localhost" se a API roda fora do compose
#   - "postgres" se a API roda DENTRO do compose
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=webapi_start

# Connection string usada pelo SQLAlchemy (geralmente não precisa alterar)
DATABASE_URL=postgresql+asyncpg://admin:admin@localhost:5432/webapi_start

# ───────────────────────── Segurança ─────────────────────────
# Gere uma chave forte com:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-please-use-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS: lista de origens separadas por vírgula
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limit padrão (requisições por minuto por IP)
RATE_LIMIT_PER_MINUTE=60

# ───────────────────────── Logging ─────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=false               # true em produção para integração com agregadores

# ───────────────────────── Bootstrap (usuário admin inicial) ─────────────────────────
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=Admin@123
